{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.NexusFeed/nexusfeed-abc",
  "description": "US liquor license compliance records (CA, TX, NY, FL, IL) with verifiable provenance.",
  "repository": {
    "url": "https://github.com/NexusFeed/nexusfeed-mcp",
    "source": "github"
  },
  "version": "1.1.1",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "nexusfeed-mcp",
      "version": "1.1.1",
      "runtimeHint": "uvx",
      "runtimeArguments": [
        { "type": "named", "name": "--from", "value": "nexusfeed-mcp" },
        { "type": "positional", "value": "nexusfeed-abc" }
      ],
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "MCP_API_BASE_URL",
          "description": "NexusFeed API base URL",
          "default": "https://api.nexusfeed.dev",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "MCP_API_KEY",
          "description": "NexusFeed API key. Get one via RapidAPI: rapidapi.com/ladourv/api/abc-license-compliance-api",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
